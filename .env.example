# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW_OHLCV=crypto.ohlcv.raw
KAFKA_CONSUMER_GROUP=etl-consumer-group

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=crypto_warehouse
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=pipeline_secret

# Data Source
DATA_SYMBOL=BTC/USDT
DATA_TIMEFRAME=1m
DATA_EXCHANGE=binance
FETCH_INTERVAL_SECONDS=60

# Spark
SPARK_MASTER=spark://localhost:7077
SPARK_APP_NAME=crypto-etl

# Airflow
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://pipeline:pipeline_secret@postgres:5432/airflow
AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://pipeline:pipeline_secret@postgres:5432/airflow

# Redis
REDIS_URL=redis://localhost:6379/0
